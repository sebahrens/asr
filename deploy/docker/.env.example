FORGEJO_ADMIN_TOKEN=

# Required by docker-compose.yml for Forgejo's effective app.ini.
# Generate local values with: node deploy/docker/prepare-env.mjs
FORGEJO_SECRET_KEY=
FORGEJO_INTERNAL_TOKEN=

# Optional LLM content screening. Leave LLM_SCREEN_PROVIDER empty to disable.
# These examples are provider-neutral starting points, not authoritative defaults.
LLM_SCREEN_PROVIDER=
LLM_SCREEN_CONTEXT_TOKENS=

# OpenAI-compatible example: OpenRouter
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1

# OpenAI-compatible example: Azure OpenAI
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://<resource-name>.openai.azure.com/openai/v1
# OPENAI_MODEL=<deployment-name>

# Anthropic-compatible example: LiteLLM proxy to Claude on Bedrock
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://litellm.example.test
ANTHROPIC_MODEL=anthropic.claude-sonnet-4-5
