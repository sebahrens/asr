FROM node:22-slim AS builder

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/cli/package.json packages/cli/package.json
COPY packages/core/package.json packages/core/package.json
COPY packages/submission/package.json packages/submission/package.json
COPY packages/web/package.json packages/web/package.json

RUN pnpm install --frozen-lockfile

COPY packages/core packages/core
COPY packages/web packages/web
COPY turbo.json ./

ARG VITE_API_URL=http://localhost:3001
ARG VITE_AUTH_MODE=mock
ARG VITE_ENABLE_MOCK_AUTH=true
ARG VITE_BRAND=pwc
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_AUTH_MODE=${VITE_AUTH_MODE}
ENV VITE_ENABLE_MOCK_AUTH=${VITE_ENABLE_MOCK_AUTH}
ENV VITE_BRAND=${VITE_BRAND}

RUN pnpm --filter @asr/web... build

FROM nginx:1.27-alpine AS runner

COPY --from=builder /app/packages/web/dist /usr/share/nginx/html

RUN printf '%s\n' \
  'server {' \
  '  listen 5173;' \
  '  server_name _;' \
  '  root /usr/share/nginx/html;' \
  '  index index.html;' \
  '  location /api/ {' \
  '    proxy_pass http://api:3001;' \
  '    proxy_http_version 1.1;' \
  '    proxy_set_header Host $host;' \
  '    proxy_set_header X-Real-IP $remote_addr;' \
  '    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;' \
  '    proxy_set_header X-Forwarded-Proto $scheme;' \
  '  }' \
  '  location / {' \
  '    try_files $uri $uri/ /index.html;' \
  '  }' \
  '}' \
  > /etc/nginx/conf.d/default.conf

EXPOSE 5173
