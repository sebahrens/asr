{
  "name": "asr",
  "version": "0.1.0",
  "description": "Self-hosted Agent Skills Registry",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "node deploy/docker/dev-api.mjs",
    "build": "turbo build",
    "test": "pnpm --filter @asr/core test",
    "test:e2e": "node ./scripts/e2e-docker.mjs",
    "cli": "pnpm --filter @asr/cli",
    "web": "pnpm --filter @asr/web"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.6.0"
  }
}
